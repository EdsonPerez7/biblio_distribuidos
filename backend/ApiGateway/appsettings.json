{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5200"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "librosRoute": {
        "ClusterId": "catalogoCluster",
        "Match": {
          "Path": "/api/Libros/{**catch-all}"
        }
      },
      "ejemplaresRoute": {
        "ClusterId": "catalogoCluster",
        "Match": {
          "Path": "/api/Ejemplares/{**catch-all}"
        }
      },
      "autoresRoute": {
        "ClusterId": "catalogoCluster",
        "Match": {
          "Path": "/api/Autores/{**catch-all}"
        }
      },
      "categoriasRoute": {
        "ClusterId": "catalogoCluster",
        "Match": {
          "Path": "/api/Categorias/{**catch-all}"
        }
      },
      "apiRoute": {
        "ClusterId": "monolitoCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "swaggerRoute": {
        "ClusterId": "monolitoCluster",
        "Match": {
          "Path": "/swagger/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "monolitoCluster": {
        "Destinations": {
          "monolito": {
            "Address": "http://localhost:5180"
          }
        }
      },
      "catalogoCluster": {
        "Destinations": {
          "catalogo": {
            "Address": "http://localhost:5201"
          }
        }
      }
    }
  }
}
